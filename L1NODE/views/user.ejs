<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title%></title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h1><%= message%></h1>
    <% if(title) { %>
    <p><%= title%></p>
    <%}else{%>
        <span>not have</span>
        <%}%>


        <ul>
            <% items.forEach(item =>{ %>

                    <li> <%= item  %></li> 
           <% })  %>
        </ul>

        <table border='2',width=200px'>
            <% user.forEach(item =>{ %>

            <tr>
                <td><%= item.name  %></td>
                <td><%= item.age  %></td>
            </tr>
           <% })  %>

        </table>
</body>
</html>